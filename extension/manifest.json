{
  "manifest_version": 3,
  "name": "HireWin — LinkedIn Optimizer",
  "version": "2.0.0",
  "description": "Score and optimize your LinkedIn profile with AI, right on the page. Get found by recruiters.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "HireWin LinkedIn Optimizer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://hirewin.live/*",
    "https://www.hirewin.live/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content-linkedin.js"],
      "css": ["panel.css"],
      "run_at": "document_idle"
    }
  ]
}
